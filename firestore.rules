rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // DEVELOPMENT MODE - Allow all access
    // TODO: Enable authentication and role-based access for production
    
    // All collections - allow public read/write for development
    match /{document=**} {
      allow read, write: if true;
    }
    
    // Production rules (commented out - uncomment when auth is enabled)
    /*
